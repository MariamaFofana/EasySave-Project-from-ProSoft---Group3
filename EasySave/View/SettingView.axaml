<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EasySave.ViewModels"
             xmlns:services="clr-namespace:EasySave.Services"
             x:DataType="vm:SettingViewModel"
             x:Class="EasySave.Views.SettingView"
             Background="White">

    <UserControl.Styles>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#cccccc"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="Background" Value="#f8fbff"/>
            <Setter Property="BorderBrush" Value="#3498db"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#e3f2fd"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">
            <TextBlock Text="{Binding [menu.settings], Source={x:Static services:LanguageManager.Instance}}" 
                       FontSize="26" FontWeight="Bold" Foreground="Black"/>
            
            <Separator Background="#eeeeee" Height="1"/>

            <!-- General Section -->
            <StackPanel Spacing="15">
                <TextBlock Text="{Binding [settings.general], Source={x:Static services:LanguageManager.Instance}}" 
                           FontSize="18" FontWeight="SemiBold" Foreground="Black"/>
                
                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding [prompt.language], Source={x:Static services:LanguageManager.Instance}}" 
                               Foreground="#333333" FontSize="14"/>
                    <ComboBox ItemsSource="{Binding AvailableLanguages}" 
                              SelectedItem="{Binding SelectedLanguage}" 
                              HorizontalAlignment="Stretch"
                              BorderBrush="#cccccc" Background="White" Foreground="Black"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding [prompt.log_format], Source={x:Static services:LanguageManager.Instance}}" 
                               Foreground="#333333" FontSize="14"/>
                    <ComboBox ItemsSource="{Binding AvailableLogFormats}" 
                              SelectedItem="{Binding SelectedLogFormat}" 
                              HorizontalAlignment="Stretch"
                              BorderBrush="#cccccc" Background="White" Foreground="Black"/>
                </StackPanel>
            </StackPanel>

            <Separator Background="#eeeeee" Height="1"/>

            <!-- System Monitoring Section -->
            <StackPanel Spacing="15">
                <TextBlock Text="{Binding [settings.monitoring], Source={x:Static services:LanguageManager.Instance}}" 
                           FontSize="18" FontWeight="SemiBold" Foreground="Black"/>
                
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding [settings.business_software], Source={x:Static services:LanguageManager.Instance}}" 
                               Foreground="#333333" FontSize="14"/>
                    <TextBox Text="{Binding BusinessSoftware}" 
                             PlaceholderText="{Binding [settings.business_software_placeholder], Source={x:Static services:LanguageManager.Instance}}"
                             BorderBrush="#cccccc" Background="White" Foreground="Black"/>
                </StackPanel>
            </StackPanel>

            <Separator Background="#eeeeee" Height="1"/>

            <!-- Encryption Section -->
            <StackPanel Spacing="15">
                <TextBlock Text="{Binding [settings.encryption], Source={x:Static services:LanguageManager.Instance}}" 
                           FontSize="18" FontWeight="SemiBold" Foreground="Black"/>
                
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding [settings.extensions], Source={x:Static services:LanguageManager.Instance}}" 
                               Foreground="#333333" FontSize="14"/>
                    <TextBox Text="{Binding ExtensionsToEncrypt}" 
                             PlaceholderText="{Binding [settings.extensions_placeholder], Source={x:Static services:LanguageManager.Instance}}"
                             BorderBrush="#cccccc" Background="White" Foreground="Black"/>
                </StackPanel>
                
                <TextBlock Text="{Binding [settings.encryption_note], Source={x:Static services:LanguageManager.Instance}}" 
                           FontSize="12" FontStyle="Italic" Foreground="#666666"/>
            </StackPanel>

            <Separator Background="#eeeeee" Height="1"/>
			<Separator Background="#eeeeee" Height="1"/>

			<!-- Section Version 3.0: Log Transmission -->
			<StackPanel Spacing="15">
				<TextBlock Text="{Binding [settings.log_transmission], Source={x:Static services:LanguageManager.Instance}}"
						   FontSize="18"
						   FontWeight="SemiBold"
						   Foreground="Black"/>

				<StackPanel Spacing="5">
					<TextBlock Text="{Binding [settings.log_mode], Source={x:Static services:LanguageManager.Instance}}"
							   Foreground="#333333"
							   FontSize="14"/>
					<ComboBox ItemsSource="{Binding AvailableLogModes}"
							  SelectedItem="{Binding SelectedLogMode}"
							  HorizontalAlignment="Stretch"
							  BorderBrush="#cccccc"
							  Background="White"
							  Foreground="Black"/>
				</StackPanel>

				<StackPanel Spacing="8">
					<TextBlock Text="{Binding [settings.log_server_url], Source={x:Static services:LanguageManager.Instance}}"
							   Foreground="#333333"
							   FontSize="14"/>
					<TextBox Text="{Binding CentralLogServerUrl}"
							 PlaceholderText="http://localhost:5000/api/logs"
							 BorderBrush="#cccccc"
							 Background="White"
							 Foreground="Black"/>
				</StackPanel>
			</StackPanel>

            <Separator Background="#eeeeee" Height="1"/>

            <!-- v3.0: Transfer Management Section (Role 2) -->
            <StackPanel Spacing="15">
                <TextBlock Text="{Binding [settings.transfer_management], Source={x:Static services:LanguageManager.Instance}}" 
                           FontSize="18" FontWeight="SemiBold" Foreground="Black"/>
                
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding [settings.priority_extensions], Source={x:Static services:LanguageManager.Instance}}" 
                               Foreground="#333333" FontSize="14"/>
                    <TextBox Text="{Binding PriorityExtensions}" 
                             PlaceholderText="e.g. .docx, .pdf, .xlsx"
                             BorderBrush="#cccccc" Background="White" Foreground="Black"/>
                    <TextBlock Text="{Binding [settings.priority_extensions_desc], Source={x:Static services:LanguageManager.Instance}}" 
                               FontSize="12" FontStyle="Italic" Foreground="#666666"/>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding [settings.large_file_threshold], Source={x:Static services:LanguageManager.Instance}}" 
                               Foreground="#333333" FontSize="14"/>
                    <TextBox Text="{Binding LargeFileThresholdKB}" 
                             PlaceholderText="e.g. 1024 (= 1 MB)"
                             BorderBrush="#cccccc" Background="White" Foreground="Black"/>
                    <TextBlock Text="{Binding [settings.large_file_threshold_desc], Source={x:Static services:LanguageManager.Instance}}" 
                               FontSize="12" FontStyle="Italic" Foreground="#666666"/>
                </StackPanel>
            </StackPanel>

            <Separator Background="#eeeeee" Height="1"/>

            <!-- Footer -->
            <TextBlock Text="{Binding [settings.auto_save], Source={x:Static services:LanguageManager.Instance}}" 
                       FontSize="13" FontStyle="Italic" Foreground="#888888"
                       HorizontalAlignment="Center" Margin="0,20,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
