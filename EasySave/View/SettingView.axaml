<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EasySave.ViewModels"
             xmlns:services="clr-namespace:EasySave.Services"
             x:DataType="vm:SettingViewModel"
             x:Class="EasySave.Views.SettingView"
             Background="White">

    <UserControl.Styles>
        <!-- Désactivation du hover pour les RadioButtons -->
        <Style Selector="RadioButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
        <Style Selector="RadioButton:pointerover /template/ Ellipse#RootEllipse">
            <Setter Property="Stroke" Value="{DynamicResource RadioButtonStroke}"/>
        </Style>

        <!-- Désactivation du hover pour les TextBox -->
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#cccccc"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">
            <!-- Titre -->
            <TextBlock Text="{Binding [menu.settings], Source={x:Static services:LanguageManager.Instance}}" 
                       FontSize="26" 
                       FontWeight="Bold" 
                       Foreground="Black"/>
            
            <Separator Background="#eeeeee" Height="1"/>

            <!-- Section Général -->
            <StackPanel Spacing="15">
                <TextBlock Text="Général" FontSize="18" FontWeight="SemiBold" Foreground="Black"/>
                
                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding [prompt.language], Source={x:Static services:LanguageManager.Instance}}" 
                               Foreground="#333333" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" Spacing="25">
                        <RadioButton Content="English" IsChecked="{Binding IsLanguageEn}" Foreground="Black"/>
                        <RadioButton Content="Français" IsChecked="{Binding IsLanguageFr}" Foreground="Black"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding [prompt.log_format], Source={x:Static services:LanguageManager.Instance}}" 
                               Foreground="#333333" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" Spacing="25">
                        <RadioButton Content="JSON" IsChecked="{Binding IsFormatJson}" Foreground="Black"/>
                        <RadioButton Content="XML" IsChecked="{Binding IsFormatXml}" Foreground="Black"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Separator Background="#eeeeee" Height="1"/>

            <!-- Section Chiffrement -->
            <StackPanel Spacing="15">
                <TextBlock Text="Chiffrement" FontSize="18" FontWeight="SemiBold" Foreground="Black"/>
                
                <StackPanel Spacing="8">
                    <TextBlock Text="Extensions à chiffrer (ex: .txt, .pdf)" 
                               Foreground="#333333" FontSize="14"/>
                    <TextBox Text="{Binding ExtensionsToEncrypt}" 
                             PlaceholderText="Séparez par des virgules..."
                             BorderBrush="#cccccc"
                             Background="White"
                             Foreground="Black"/>
                </StackPanel>
                
                <TextBlock Text="Note: La clé de chiffrement est sécurisée en interne." 
                           FontSize="12" 
                           FontStyle="Italic" 
                           Foreground="#666666"/>
            </StackPanel>

            <Separator Background="#eeeeee" Height="1"/>

            <!-- Footer Info -->
            <TextBlock Text="Les modifications sont enregistrées automatiquement." 
                       FontSize="13" 
                       FontStyle="Italic" 
                       Foreground="#888888"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
