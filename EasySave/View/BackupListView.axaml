<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EasySave.ViewModels"
             xmlns:models="using:EasySave.Models"
             xmlns:services="clr-namespace:EasySave.Services"
             x:DataType="vm:BackupListViewModel"
             x:Class="EasySave.Views.BackupListView"
             Background="White">

	<UserControl.Styles>
		<Style Selector="Button.action-btn">
			<Setter Property="Width" Value="34"/>
			<Setter Property="Height" Value="34"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="Background" Value="#f0f0f0"/>
			<Setter Property="BorderBrush" Value="#dddddd"/>
			<Setter Property="CornerRadius" Value="17"/>
		</Style>

		<Style Selector="CheckBox">
			<Setter Property="BorderBrush" Value="#aaaaaa"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="Padding" Value="0"/>
		</Style>

		<Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
			<Setter Property="BorderBrush" Value="#3498db"/>
		</Style>

		<Style Selector="Border.panel-card">
			<Setter Property="Background" Value="#f5f5f5"/>
			<Setter Property="BorderBrush" Value="#dddddd"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16"/>
		</Style>

		<Style Selector="Border.content-card">
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#dddddd"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="18"/>
		</Style>
	</UserControl.Styles>

	<Grid ColumnDefinitions="*,260" Margin="20" ColumnSpacing="20">

		<!-- Zone centrale -->
		<Grid Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="16">

			<!-- Header -->
			<Border Grid.Row="0" Classes="content-card">
				<StackPanel Spacing="14">
							   <TextBlock Text="Your backup jobs" 
							   FontSize="26"
							   FontWeight="Bold"
							   Foreground="Black"/>

					<StackPanel Orientation="Horizontal" Spacing="16">
						<StackPanel Spacing="4" Width="140">
							<TextBlock Text="Mode"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Foreground="#555555"/>
							<ComboBox ItemsSource="{Binding AvailableLogModes}"
									  SelectedItem="{Binding SelectedLogMode}"
									  HorizontalAlignment="Stretch"/>
						</StackPanel>

						<StackPanel Spacing="4" Width="140">
							<TextBlock Text="Format"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Foreground="#555555"/>
							<ComboBox ItemsSource="{Binding AvailableLogFormats}"
									  SelectedItem="{Binding SelectedLogFormat}"
									  HorizontalAlignment="Stretch"/>
						</StackPanel>

						<StackPanel Spacing="4" Width="140">
							<TextBlock Text="Language"
									   FontSize="12"
									   FontWeight="SemiBold"
									   Foreground="#555555"/>
							<ComboBox ItemsSource="{Binding AvailableLanguages}"
									  SelectedItem="{Binding SelectedLanguage}"
									  HorizontalAlignment="Stretch"/>
						</StackPanel>
					</StackPanel>

					<TextBlock Text="View and control the progress of each backup."
							   FontSize="13"
							   Foreground="#666666"/>
				</StackPanel>
			</Border>

			<!-- Liste des jobs -->
			<Border Grid.Row="1" Classes="content-card">
				<ScrollViewer>
					<ItemsControl ItemsSource="{Binding Jobs}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="models:BackupJob">
								<Border Background="White"
										BorderBrush="#dddddd"
										BorderThickness="1"
										CornerRadius="8"
										Padding="16"
										Margin="0,0,0,14">

									<Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="8">

										<!-- Colonne gauche -->
										<CheckBox Grid.Row="0" Grid.RowSpan="3"
												  Grid.Column="0"
												  IsChecked="{Binding IsSelected}"
												  VerticalAlignment="Top"
												  Margin="0,6,0,0"/>

										<!-- Ligne 1 : nom / type / statut / % -->
										<Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="14">
											<StackPanel Spacing="2">
												<TextBlock Text="{Binding Name}"
														   FontWeight="Bold"
														   FontSize="16"
														   Foreground="Black"/>

												<TextBlock Text="{Binding Type, Converter={StaticResource TypeTranslatorConverter}}"
														   FontSize="11"
														   Foreground="#666666"/>
											</StackPanel>

											<!-- Badge statut -->
											<Border Grid.Column="1"
													Background="#F3F4F6"
													BorderBrush="#DDDDDD"
													BorderThickness="1"
													CornerRadius="12"
													Padding="10,3"
													VerticalAlignment="Center">
												<TextBlock Text="{Binding Status, Converter={StaticResource StatusTranslatorConverter}}"
														   FontSize="11"
														   FontWeight="SemiBold"
														   Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
											</Border>

											<!-- Pourcentage -->
											<TextBlock Grid.Column="2"
													   Text="{Binding Progression, StringFormat={}{0}%}"
													   FontSize="14"
													   FontWeight="SemiBold"
													   Foreground="#222222"
													   VerticalAlignment="Center"/>
										</Grid>

										<!-- Ligne 2 : source / cible -->
										<Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="4" ColumnSpacing="6">
											<TextBlock Grid.Row="0" Grid.Column="0"
													   Text="Source :"
													   FontSize="11"
													   FontWeight="SemiBold"
													   Foreground="#777777"/>

											<TextBlock Grid.Row="0" Grid.Column="1"
													   Text="{Binding SourceDirectory}"
													   FontSize="11"
													   Foreground="#777777"
													   TextTrimming="CharacterEllipsis"
													   MaxWidth="420"/>

											<TextBlock Grid.Row="1" Grid.Column="0"
													   Text="Target :"
													   FontSize="11"
													   FontWeight="SemiBold"
													   Foreground="#777777"/>

											<TextBlock Grid.Row="1" Grid.Column="1"
													   Text="{Binding TargetDirectory}"
													   FontSize="11"
													   Foreground="#777777"
													   TextTrimming="CharacterEllipsis"
													   MaxWidth="420"/>
										</Grid>

										<!-- Ligne 3 : progression + infos -->
										<StackPanel Grid.Row="2" Grid.Column="1" Spacing="6">
											<ProgressBar Value="{Binding Progression}"
														 Maximum="100"
														 Height="6"
														 Background="#ECECEC"
														 Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>

											<TextBlock Text="{Binding ErrorMessage}"
													   FontSize="11"
													   Foreground="#666666"
													   TextWrapping="Wrap"/>
										</StackPanel>

										<!-- Colonne droite : actions -->
										<StackPanel Grid.Row="0" Grid.RowSpan="3"
													Grid.Column="2"
													Orientation="Horizontal"
													Spacing="10"
													VerticalAlignment="Center">
											<Button Classes="action-btn"
													Content="▶"
													Command="{Binding $parent[UserControl].DataContext.PlayJob}"
													CommandParameter="{Binding}"
													ToolTip.Tip="{Binding [actions.play], Source={x:Static services:LanguageManager.Instance}}"/>

											<Button Classes="action-btn"
													Content="⏸"
													Command="{Binding $parent[UserControl].DataContext.PauseJob}"
													CommandParameter="{Binding}"
													ToolTip.Tip="{Binding [actions.pause], Source={x:Static services:LanguageManager.Instance}}"/>

											<Button Classes="action-btn"
													Content="⏹"
													Command="{Binding $parent[UserControl].DataContext.StopJob}"
													CommandParameter="{Binding}"
													ToolTip.Tip="{Binding [actions.stop], Source={x:Static services:LanguageManager.Instance}}"/>

											<Button Classes="action-btn"
													Content="X"
													Command="{Binding $parent[UserControl].DataContext.DeleteJob}"
													CommandParameter="{Binding}"
													Foreground="#e74c3c"
													ToolTip.Tip="{Binding [actions.delete], Source={x:Static services:LanguageManager.Instance}}"/>
										</StackPanel>

									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
						
					</ItemsControl>
					
					
				</ScrollViewer>
			</Border>
		</Grid>

		
		<!-- Panneau droit -->
		<Border Grid.Column="1" Classes="panel-card">
			<StackPanel Spacing="14">
				<TextBlock Text="Actions"
						   FontSize="18"
						   FontWeight="Bold"
						   Foreground="Black"/>

				<Button Classes="side-action-btn primary"
						Content="+   Nouveau travail"
						Command="{Binding NewJob}"/>

				<Button Classes="side-action-btn neutral"
						Content="▷   Exécuter sélection"
						Command="{Binding RunSelectedJobs}"/>

				<Button Classes="side-action-btn success"
						Content="▷▷   Tout exécuter"
						Command="{Binding RunAllJobs}"/>

				<Button Classes="side-action-btn warning"
						Content="❚❚   Pause tout"
						Command="{Binding PauseAllJobs}"/>

				<Button Classes="side-action-btn neutral"
						Content="▷   Reprendre tout"
						Command="{Binding ResumeAllJobs}"/>

				<Button Classes="side-action-btn danger"
						Content="■   Arrêter tout"
						Command="{Binding StopAllJobs}"/>

				<Separator Margin="0,6,0,6"/>

				<TextBlock Text="Selection Summary"
						   FontSize="16"
						   FontWeight="SemiBold"
						   Foreground="Black"/>

				<StackPanel Spacing="4">
					<TextBlock Text="{Binding TotalJobsCount, StringFormat=Total jobs: {0}}"
							   Foreground="#555555"/>
					<TextBlock Text="{Binding SelectedJobsCount, StringFormat=Selected jobs: {0}}"
							   Foreground="#555555"/>
				</StackPanel>

				<Separator Margin="0,6,0,6"/>

				<TextBlock Text="Reason / Exception"
						   FontSize="16"
						   FontWeight="SemiBold"
						   Foreground="Black"/>

				<Border Background="#FFF7ED"
						BorderBrush="#FDBA74"
						BorderThickness="1"
						CornerRadius="8"
						Padding="12">
					<StackPanel Spacing="6">
						<TextBlock Text="No current blocking issue."
								   Foreground="#9A3412"
								   FontWeight="SemiBold"/>

						<TextBlock Text="This panel can display business software pause, priority waiting, large file blocking, or the latest execution error."
								   TextWrapping="Wrap"
								   FontSize="12"
								   Foreground="#7C2D12"/>
					</StackPanel>
				</Border>
			</StackPanel>
		</Border>

	</Grid>
</UserControl>