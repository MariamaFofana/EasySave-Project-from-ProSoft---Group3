<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EasySave.ViewModels"
             xmlns:models="using:EasySave.Models"
             xmlns:services="clr-namespace:EasySave.Services"
             x:DataType="vm:BackupListViewModel"
             x:Class="EasySave.Views.BackupListView"
             Background="White">

    <UserControl.Styles>
        <Style Selector="Button.action-btn">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#f0f0f0"/>
            <Setter Property="BorderBrush" Value="#dddddd"/>
            <Setter Property="CornerRadius" Value="17"/> <!-- Circular -->
        </Style>

        <!-- Make CheckBox visible on white background and adjust size -->
        <Style Selector="CheckBox">
            <Setter Property="BorderBrush" Value="#aaaaaa"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
            <Setter Property="BorderBrush" Value="#3498db"/>
        </Style>
    </UserControl.Styles>

    <DockPanel Margin="30">
        <TextBlock DockPanel.Dock="Top" 
                   Text="{Binding [jobs.list_title], Source={x:Static services:LanguageManager.Instance}}" 
                   FontSize="26" 
                   FontWeight="Bold" 
                   Foreground="Black" 
                   Margin="0,0,0,20"/>

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Jobs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:BackupJob">
                        <Border BorderBrush="#eeeeee" BorderThickness="0,0,0,1" Padding="15,12">
                            <Grid ColumnDefinitions="Auto, 2*, 1.5*, 0.5*, Auto, Auto">
                                <!-- Selection -->
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <!-- Info -->
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Foreground="Black"/>
                                    <TextBlock Text="{Binding Type, Converter={StaticResource TypeTranslatorConverter}}" FontSize="11" Foreground="#666666" Margin="0,0,0,4"/>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="Src:" FontSize="10" FontWeight="SemiBold" Foreground="#999999"/>
                                        <TextBlock Text="{Binding SourceDirectory}" FontSize="10" Foreground="#888888" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="Dst:" FontSize="10" FontWeight="SemiBold" Foreground="#999999"/>
                                        <TextBlock Text="{Binding TargetDirectory}" FontSize="10" Foreground="#888888" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Progress/Details -->
                                <StackPanel Grid.Column="2" Margin="20,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusTranslatorConverter}}" 
                                               FontSize="12" 
                                               FontWeight="SemiBold" 
                                               Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                               ToolTip.Tip="{Binding ErrorMessage}"/>

                                    <ProgressBar Value="{Binding Progression}" 
                                                 Maximum="100" 
                                                 Height="4" 
                                                 Margin="0,4,20,0" 
                                                 Background="#f0f0f0" 
                                                 Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Progression, StringFormat={}{0}%}" FontSize="12" Foreground="#333333"/>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="20,0">
                                    <Button Classes="action-btn" Content="▶" 
                                            Command="{Binding $parent[UserControl].DataContext.PlayJob}" 
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding [actions.play], Source={x:Static services:LanguageManager.Instance}}"/>
                                    
                                    <Button Classes="action-btn" Content="⏸" 
                                            Command="{Binding $parent[UserControl].DataContext.PauseJob}" 
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding [actions.pause], Source={x:Static services:LanguageManager.Instance}}"/>
                                    
                                    <Button Classes="action-btn" Content="⏹" 
                                            Command="{Binding $parent[UserControl].DataContext.StopJob}" 
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding [actions.stop], Source={x:Static services:LanguageManager.Instance}}"/>
                                </StackPanel>

                                <Button Grid.Column="5" Classes="action-btn" Content="X" 
                                        Command="{Binding $parent[UserControl].DataContext.DeleteJob}" 
                                        CommandParameter="{Binding}"
                                        Foreground="#e74c3c"
                                        ToolTip.Tip="{Binding [actions.delete], Source={x:Static services:LanguageManager.Instance}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
